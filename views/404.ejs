<%- include('partials/head') %>
<%- include('partials/header') %>

<section class="section">
  <div class="wrap narrow notfound">
    <svg class="notfound-art" viewBox="0 0 320 120" aria-hidden="true">
      <path d="M0 110 L60 40 L95 78 L140 20 L185 75 L225 45 L275 100 L320 70 L320 120 L0 120 Z" fill="var(--green-100)"/>
      <path d="M20 120 L90 60 L130 95 L180 50 L240 110 L280 85 L320 120 Z" fill="var(--green-700)" opacity="0.75"/>
      <circle cx="262" cy="26" r="13" fill="var(--accent)" opacity="0.85"/>
    </svg>
    <% if (typeof is500 !== 'undefined' && is500) { %>
      <h1>Oi – noe gikk galt</h1>
      <p>Prøv igjen om et øyeblikk, eller gå tilbake til forsiden.</p>
    <% } else { %>
      <h1>Fant ikke siden</h1>
      <p>Siden du leter etter finnes ikke – kanskje den har gått seg vill på fjellet.</p>
    <% } %>
    <a class="btn btn-primary" href="/">Til forsiden</a>
  </div>
</section>

<%- include('partials/footer') %>
