<!DOCTYPE html>
<html lang="nb">
<head>
<meta charset="utf-8">
<meta name="viewport" content="width=device-width, initial-scale=1">
<meta name="robots" content="noindex, nofollow">
<title><%= typeof pageTitle !== 'undefined' ? pageTitle : 'Admin' %> | Skogstad demo</title>
<link rel="icon" type="image/svg+xml" href="/images/logo-icon.svg">
<link rel="preload" href="/fonts/figtree-latin-ext-wght.woff2" as="font" type="font/woff2" crossorigin>
<link rel="stylesheet" href="/css/admin.css">
</head>
<body class="admin-body">
<header class="admin-topbar">
  <button class="admin-nav-toggle" aria-expanded="false" aria-controls="adminnav" aria-label="Meny">☰</button>
  <a class="admin-logo" href="/admin"><img src="/images/logo-icon.svg" alt="" width="22" height="22"> Skogstad <span>admin</span></a>
  <div class="admin-topbar-right">
    <a href="/" target="_blank" rel="noopener">Se siden ↗</a>
    <a href="/admin/logout">Logg ut</a>
  </div>
</header>
<div class="admin-shell">
<nav id="adminnav" class="admin-sidenav" aria-label="Adminmeny">
  <a class="side-link <%= path === '/admin' ? 'is-active' : '' %>" href="/admin">
    <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true"><path d="M3 11l9-8 9 8"/><path d="M5 10v10h14V10"/></svg>Oversikt</a>
  <p class="side-group">Butikk</p>
  <a class="side-link <%= path.startsWith('/admin/produkter') ? 'is-active' : '' %>" href="/admin/produkter">
    <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true"><path d="M6 7h12l1 13H5L6 7z"/><path d="M9 7a3 3 0 0 1 6 0"/></svg>Produkter</a>
  <a class="side-link <%= path.startsWith('/admin/kampanjer') ? 'is-active' : '' %>" href="/admin/kampanjer">
    <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true"><path d="M20 13l-7 7-9-9V4h7l9 9z"/><circle cx="7.5" cy="7.5" r="1.5"/></svg>Kampanjer</a>
  <a class="side-link <%= path.startsWith('/admin/klubb') ? 'is-active' : '' %>" href="/admin/klubb">
    <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true"><circle cx="12" cy="8" r="4"/><path d="M4 21c0-4 3.6-6 8-6s8 2 8 6"/></svg>Kundeklubb</a>
  <p class="side-group">Innhold</p>
  <a class="side-link <%= path.startsWith('/admin/innhold') ? 'is-active' : '' %>" href="/admin/innhold">
    <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true"><path d="M4 20h16"/><path d="M6 16L16 6l2 2L8 18l-3 1 1-3z"/></svg>Tekster</a>
  <a class="side-link <%= path.startsWith('/admin/bilder') ? 'is-active' : '' %>" href="/admin/bilder">
    <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true"><rect x="3" y="5" width="18" height="14" rx="2"/><circle cx="9" cy="10" r="1.5"/><path d="M3 17l5-4 4 3 4-4 5 5"/></svg>Bilder</a>
  <a class="side-link <%= path.startsWith('/admin/butikker') ? 'is-active' : '' %>" href="/admin/butikker">
    <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true"><path d="M4 9l1-5h14l1 5"/><path d="M5 9v11h14V9"/><path d="M9 20v-6h6v6"/></svg>Butikker</a>
  <a class="side-link <%= path.startsWith('/admin/varsel') ? 'is-active' : '' %>" href="/admin/varsel">
    <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true"><path d="M12 3v10"/><circle cx="12" cy="18" r="1.5"/></svg>Varsellinje</a>
  <a class="side-link <%= path.startsWith('/admin/seo') ? 'is-active' : '' %>" href="/admin/seo">
    <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true"><circle cx="10" cy="10" r="6"/><path d="M20 20l-5.5-5.5"/></svg>SEO</a>
  <p class="side-group">Utseende</p>
  <a class="side-link <%= path.startsWith('/admin/tema') ? 'is-active' : '' %>" href="/admin/tema">
    <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true"><path d="M12 21a9 9 0 1 1 9-9c0 2-1.5 3-3 3h-2a2 2 0 0 0-2 2c0 1.5 1 2-.5 3.4A8 8 0 0 1 12 21z"/><circle cx="8" cy="10" r="1"/><circle cx="12" cy="7" r="1"/><circle cx="16" cy="10" r="1"/></svg>Tema</a>
  <p class="side-group">System</p>
  <a class="side-link <%= path.startsWith('/admin/meldinger') ? 'is-active' : '' %>" href="/admin/meldinger">
    <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true"><rect x="3" y="5" width="18" height="14" rx="2"/><path d="M3 7l9 6 9-6"/></svg>Meldinger</a>
  <a class="side-link <%= path.startsWith('/admin/innstillinger') ? 'is-active' : '' %>" href="/admin/innstillinger">
    <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true"><circle cx="12" cy="12" r="3"/><path d="M19 12a7 7 0 0 0-.1-1.2l2-1.6-2-3.4-2.4 1a7 7 0 0 0-2-1.2L14 3h-4l-.4 2.6a7 7 0 0 0-2 1.2l-2.4-1-2 3.4 2 1.6A7 7 0 0 0 5 12c0 .4 0 .8.1 1.2l-2 1.6 2 3.4 2.4-1a7 7 0 0 0 2 1.2L10 21h4l.4-2.6a7 7 0 0 0 2-1.2l2.4 1 2-3.4-2-1.6c.1-.4.2-.8.2-1.2z"/></svg>Innstillinger</a>
</nav>
<main class="admin-main">
<% if (typeof saved !== 'undefined' && saved) { %><p class="admin-flash" role="status">Lagret ✓</p><% } %>
