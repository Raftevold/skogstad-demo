<%- include('partials/top', { pageTitle: 'Produkter' }) %>
<div class="page-actions">
  <h1>Produkter</h1>
  <a class="admin-btn admin-btn-primary" href="/admin/produkter/ny">＋ Nytt produkt</a>
</div>
<div class="table-scroll">
<table class="admin-table">
  <thead><tr><th scope="col">Produkt</th><th scope="col">Kategori</th><th scope="col">Pris</th><th scope="col">Status</th><th scope="col">Handling</th></tr></thead>
  <tbody>
    <% products.forEach(function (p) { %>
      <tr>
        <td class="cell-product">
          <img class="row-thumb" src="<%= p.image && p.image.startsWith('/media/') ? p.image : (p.image ? p.image + '-300.jpg' : '/images/logo-icon.svg') %>" alt="" width="44" height="44" loading="lazy">
          <span>
            <a href="/admin/produkter/<%= p.id %>"><%= p.name %></a>
            <% if (p.placeholder) { %><span class="pill pill-warn">placeholder</span><% } %>
          </span>
        </td>
        <td><%= p.category %></td>
        <td><%= p.price %>,-</td>
        <td>
          <span class="pill <%= p.active ? 'pill-ok' : 'pill-off' %>"><%= p.active ? 'Aktiv' : 'Skjult' %></span>
          <% if (p.featured) { %><span class="pill">Forside</span><% } %>
        </td>
        <td class="row-actions">
          <a class="admin-btn" href="/admin/produkter/<%= p.id %>">Rediger</a>
          <a class="admin-btn" href="/produkt/<%= p.slug %>" target="_blank" rel="noopener">Vis ↗</a>
          <form method="post" action="/admin/produkter/<%= p.id %>/slett" data-confirm="Slette «<%= p.name %>»?">
            <button class="admin-btn admin-btn-danger" type="submit">Slett</button>
          </form>
        </td>
      </tr>
    <% }) %>
  </tbody>
</table>
</div>
<%- include('partials/bottom') %>
