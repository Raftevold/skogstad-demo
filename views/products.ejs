<%- include('partials/head') %>
<%- include('partials/header') %>

<section class="page-head">
  <div class="wrap">
    <h1><%= heading %></h1>
    <nav class="filter-chips" aria-label="Kategorifilter">
      <a class="chip <%= !activeCategory ? 'is-active' : '' %>" href="/produkter" <%= !activeCategory ? 'aria-current="page"' : '' %>>Alle</a>
      <% Object.entries(categories).forEach(function ([key, label]) { %>
        <a class="chip <%= activeCategory === key ? 'is-active' : '' %>" href="/produkter/<%= key %>" <%= activeCategory === key ? 'aria-current="page"' : '' %>><%= label %></a>
      <% }) %>
    </nav>
    <% if (tier) { %>
      <p class="member-note">Du ser prisene som <strong><%= club.tiers[tier].label %></strong>-medlem (demo). <a href="/demo/medlem/av">Vis ordinære priser</a></p>
    <% } %>
  </div>
</section>

<section class="section">
  <div class="wrap">
    <% if (products.length === 0) { %>
      <p>Ingen produkter i denne kategorien ennå.</p>
    <% } else { %>
      <div class="list-toolbar">
        <p class="list-count"><%= products.length %> produkter</p>
        <form method="get" class="sort-form">
          <label for="sortering">Sorter:</label>
          <select id="sortering" name="sortering" data-auto-submit>
            <option value="" <%= !sortering ? 'selected' : '' %>>Anbefalt</option>
            <option value="pris-lav" <%= sortering === 'pris-lav' ? 'selected' : '' %>>Pris: lav–høy</option>
            <option value="pris-hoy" <%= sortering === 'pris-hoy' ? 'selected' : '' %>>Pris: høy–lav</option>
          </select>
        </form>
      </div>
      <div class="product-grid">
        <% products.forEach(function (p) { %>
          <%- include('partials/product-card', { p, pr: prices[p.slug] }) %>
        <% }) %>
      </div>
    <% } %>
  </div>
</section>

<%- include('partials/footer') %>
